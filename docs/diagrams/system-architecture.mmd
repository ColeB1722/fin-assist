graph TD
    subgraph Clients
        CLI["CLI Client<br/>Rich + httpx + prompt-toolkit"]
        TUI["TUI Client (planned)<br/>Textual"]
    end

    subgraph "A2A Protocol — HTTP + JSON-RPC"
        RPC["SendMessage · SendStreamingMessage (SSE)<br/>Agent discovery via Agent Cards"]
    end

    subgraph "Agent Hub — FastAPI on 127.0.0.1:4096"
        HUB["Hub Router<br/>GET /agents · GET /health"]

        subgraph "Per-Agent A2A Sub-Apps"
            D["/default/<br/>do + talk · chain-of-thought"]
            S["/shell/<br/>do only · approval gate"]
            F["/{name}/<br/>future agents"]
        end

        EXEC["FinAssistExecutor<br/>AgentExecutor + TaskUpdater"]
        TS["InMemoryTaskStore<br/>ephemeral (a2a-sdk)"]
        CS["ContextStore<br/>SQLite — conversation history"]
    end

    subgraph "Shared Services"
        CREDS["CredentialStore<br/>env → file → keyring"]
        CONFIG["ConfigLoader<br/>TOML · 4-level priority"]
        CTXP["ContextProviders<br/>files · git · history · env"]
        REG["ProviderRegistry<br/>LLM providers"]
    end

    LLM["pydantic-ai → LLM Providers"]

    CLI --> RPC
    TUI --> RPC
    RPC --> HUB
    HUB --> D & S & F
    D & S & F --> EXEC
    EXEC --> LLM
    EXEC --> TS & CS
    LLM --> CREDS & REG
    EXEC --> CTXP
    HUB -.-> CONFIG
